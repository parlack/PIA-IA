{
  "expo": {
    "name": "PIA-IA Cartilla",
    "slug": "pia-ia-cartilla",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "piaia",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0E5037",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.piaia.cartilla",
      "infoPlist": {
        "NSCameraUsageDescription": "PIA-IA usa la camara para escanear el codigo QR del ciudadano y registrar dosis aplicadas."
      }
    },
    "android": {
      "package": "mx.piaia.cartilla",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E5037"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "PIA-IA usa la camara para escanear el codigo QR del ciudadano y registrar dosis aplicadas."
        }
      ],
      "expo-video",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
