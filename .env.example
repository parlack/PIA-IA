# Variables de entorno PIA-IA (copia este archivo a `.env` y completa los valores)

# --- Base de datos MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=pia_ia

# --- CORS (separar por comas) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# --- Correo transaccional (Yolani Mail API) ---
# Doc: https://docs.yolani.co/api-correo/introduccion
YOLANI_MAIL_API_URL=https://api.yolani.co
YOLANI_MAIL_API_KEY=yk-...
YOLANI_MAIL_DOMAIN=yolani.co
YOLANI_MAIL_FROM=PIA-IA <no-reply@yolani.co>
